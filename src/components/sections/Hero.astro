---
import { ArrowDown } from 'lucide-react';
import AnimatedButtons from '@/components/blocks/AnimatedButtons.astro';
import AnimatedText from '@/components/blocks/AnimatedText.astro';
---

<div class="lazyload shaded relative h-svh">
  <div class="hero-video-wrapper absolute inset-0 overflow-hidden">
    <video
      autoplay
      loop
      muted
      poster="/assets/video_poster.avif"
      class="hero-video h-full w-full object-cover"
    >
      <source src="/assets/waves.webm" type="video/webm" />
      <source src="/assets/waves.mp4" type="video/mp4" />
    </video>
    <div class="darken absolute inset-0 bg-black/20"></div>
  </div>
  <div class="absolute inset-0 z-10 flex flex-col items-center justify-center p-8">
    <div class="text-center">
      <h1 aria-label="Stefano D'Ambrosio, Front End Developer">
        <AnimatedText
          text="Stefano"
          className="font-serif text-4xl tracking-wide text-white italic xl:text-5xl"
        />
        <AnimatedText
          text="D'Ambrosio"
          delay={0.4}
          className="font-serif text-4xl tracking-wide text-white italic xl:text-5xl"
        />
      </h1>
      <h2 aria-label="Front End Developer">
        <AnimatedText
          text="Front End Developer"
          delay={0}
          className="mt-2 text-lg font-light tracking-wide text-gray-200 md:text-lg"
        />
      </h2>
      <AnimatedButtons />
      <div
        class="hover:text-primary absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce text-white transition-colors"
      >
        <a href="#tech" class="scroll-to-link" aria-label="Scroll to About section">
          <ArrowDown size={24} />
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  const video = document.querySelector<HTMLVideoElement>('.hero-video');
  let ticking = false;
  window.addEventListener(
    'scroll',
    () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          if (video) {
            video.style.transform = `translateY(${window.scrollY * 0.3}px)`;
          }
          ticking = false;
        });
        ticking = true;
      }
    },
    { passive: true }
  );

  document.querySelectorAll<HTMLAnchorElement>('.scroll-to-link').forEach((el) => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      const href = el.getAttribute('href');
      if (href?.startsWith('#')) {
        document.querySelector(href)?.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });
</script>
