---
import { Github, ExternalLink } from 'lucide-react';
import Card from '@/components/ui/card.astro';
import Button from '@/components/ui/button.astro';
import { projects } from '@/data/projects';
import { Image } from 'astro:assets';
---

<section id="projects" class="relative overflow-hidden py-20">
  <!-- Background gradients -->
  <div class="bg-background absolute inset-0">
    <div
      class="absolute inset-0 bg-[radial-gradient(at_47%_33%,hsl(0,0%,100%)_0,transparent_59%)] opacity-10"
    >
    </div>
  </div>

  <div class="relative mx-auto max-w-6xl px-4">
    <h2 class="mb-12 text-center font-serif text-3xl font-normal italic md:text-4xl">
      Featured Projects
    </h2>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
      {
        projects.map((project) => (
          <Card color={project.color} class={`overflow-hidden p-6 ${project.border}`}>
            <div class="relative mb-4 h-60 overflow-hidden rounded-lg">
              <Image
                src={project.image}
                alt={project.title}
                width={380}
                height={300}
                class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
              />
            </div>
            <div class="relative space-y-4">
              <h3 class="text-xl font-bold">{project.title}</h3>
              <p class="text-muted-foreground">{project.description}</p>
              <div class="mt-auto flex w-full flex-wrap gap-4">
                <Button
                  href={project.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  variant="glass"
                  class={`flex flex-1 items-center justify-center gap-2 ${project.border}`}
                >
                  <Github className="size-4" />
                  <span class="font-medium lg:text-sm">GitHub</span>
                </Button>
                <Button
                  href={project.demo}
                  target="_blank"
                  rel="noopener noreferrer"
                  variant="glass"
                  class={`flex flex-1 items-center justify-center gap-2 ${project.border}`}
                >
                  <ExternalLink className="size-4" />
                  <span class="font-medium lg:text-sm">Live Demo</span>
                </Button>
              </div>
            </div>
          </Card>
        ))
      }
    </div>
  </div>
</section>
