---
import Button from '@/components/ui/button.astro';
import MobileMenu from '@/components/react/MobileMenu';
import { routes } from '@/data/routes';

const isHome = Astro.url.pathname === '/';
const navRoutes = isHome ? routes : [{ name: 'Home', href: '/' }];
---

<div id="navbar" class="absolute top-0 left-0 z-50 w-full transform transition-all duration-300">
  {/* Mobile Menu */}
  <MobileMenu client:load />

  {/* Desktop Menu */}
  <div class="hidden justify-center gap-4 p-6 lg:flex">
    {
      navRoutes.map((route) => (
        <Button
          variant="link"
          size="sm"
          class="px-2 text-2xl opacity-90"
          href={isHome || route.href.startsWith('/') ? route.href : '/' + route.href}
          data-scroll-to
        >
          {route.name}
        </Button>
      ))
    }
  </div>
</div>

<script>
  const navbar = document.getElementById('navbar');
  const getScrollY = () => {
    const m = document.documentElement.style.transform.match(/translate3d\(0px,\s*(-?\d+)/);
    return m ? Math.abs(parseInt(m[1])) : window.scrollY;
  };
  let lastScroll = getScrollY();

  const handleScroll = () => {
    const currentScroll = getScrollY();

    if (currentScroll > window.innerHeight * 0.8) {
      // After 80%, show navbar with animation
      navbar?.classList.remove('absolute', 'hidden');
      navbar?.classList.add('fixed', 'bg-background/80', 'backdrop-blur-lg', 'shadow-md');

      if (currentScroll < lastScroll) {
        // Scrolling up after 80%
        navbar?.classList.remove('-translate-y-full');
        navbar?.classList.add('translate-y-0');
      } else {
        // Scrolling down after 80%
        navbar?.classList.remove('translate-y-0');
        navbar?.classList.add('-translate-y-full');
      }
    } else if (currentScroll > window.innerHeight * 0.5) {
      // Between 50% and 80%, hide navbar
      navbar?.classList.remove('absolute', 'translate-y-0');
      navbar?.classList.add(
        'hidden',
        'fixed',
        '-translate-y-full',
        'bg-background/80',
        'backdrop-blur-lg',
        'shadow-md'
      );
    } else {
      // Before 50%, show navbar at top
      navbar?.classList.remove(
        'hidden',
        'fixed',
        '-translate-y-full',
        'translate-y-0',
        'bg-background/80',
        'backdrop-blur-lg',
        'shadow-md'
      );
      navbar?.classList.add('absolute');
    }

    lastScroll = currentScroll;
  };

  window.addEventListener('scroll', handleScroll);
</script>
