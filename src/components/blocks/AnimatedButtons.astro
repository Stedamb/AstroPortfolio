---
import Button from '@/components/ui/button.astro';
import { socialLinks } from '@/data/site';
---

<div class="mx-auto grid w-fit grid-cols-3 gap-4 pt-4">
  <Button
    href={socialLinks.github}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Visit my GitHub profile"
    variant="outline"
    size="icon"
    style="animation-delay: 0.3s"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      ><path
        d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
      ></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
    >
    <span class="sr-only">GitHub</span>
  </Button>
  <Button
    href={socialLinks.linkedin}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Visit my LinkedIn profile"
    variant="outline"
    size="icon"
    style="animation-delay: 0.4s"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      ><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
      ></path><rect width="4" height="12" x="2" y="9"></rect><circle cx="4" cy="4" r="2"
      ></circle></svg
    >
    <span class="sr-only">LinkedIn</span>
  </Button>
  <Button
    href={socialLinks.email}
    aria-label="Send me an email"
    variant="outline"
    size="icon"
    style="animation-delay: 0.5s"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      ><rect width="20" height="16" x="2" y="4" rx="2"></rect><path
        d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
    >
    <span class="sr-only">Email</span>
  </Button>
  <Button
    href={socialLinks.cv}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Download CV"
    variant="outline"
    size="fluid"
    class="col-span-3 h-9"
    style="animation-delay: 0.6s"
  >
    <span>CV</span>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      ><circle cx="12" cy="12" r="10"></circle><path d="M12 8v8"></path><path d="m8 12 4 4 4-4"
      ></path></svg
    >
  </Button>
</div>

<style>
  @keyframes btnReveal {
    0% {
      opacity: 0;
      transform: translateY(10px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  a {
    opacity: 1;
    transform: translateY(0);
    animation: btnReveal 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    transition:
      background-color 0.2s,
      border-color 0.2s;
  }
</style>
