---
import Button from '@/components/ui/button.astro';
import { socialLinks } from '@/data/site';
---

<div class="mx-auto grid w-fit grid-cols-3 gap-4 pt-4">
  <Button
    href={socialLinks.github}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Visit my GitHub profile"
    variant="outline"
    size="icon"
    style="animation-delay: 0.3s"
  >
    <svg class="h-6 w-6" aria-hidden="true">
      <use href="/icons/icons.svg#github"></use>
    </svg>
    <span class="sr-only">GitHub</span>
  </Button>
  <Button
    href={socialLinks.linkedin}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Visit my LinkedIn profile"
    variant="outline"
    size="icon"
    style="animation-delay: 0.4s"
  >
    <svg class="h-6 w-6" aria-hidden="true">
      <use href="/icons/icons.svg#linkedin"></use>
    </svg>
    <span class="sr-only">LinkedIn</span>
  </Button>
  <Button
    href={socialLinks.email}
    aria-label="Send me an email"
    variant="outline"
    size="icon"
    style="animation-delay: 0.5s"
  >
    <svg class="h-6 w-6" aria-hidden="true">
      <use href="/icons/icons.svg#mail"></use>
    </svg>
    <span class="sr-only">Email</span>
  </Button>
  <Button
    href={socialLinks.cv}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Download CV"
    variant="outline"
    size="fluid"
    class="col-span-3 h-9"
    style="animation-delay: 0.6s"
  >
    <span>CV</span>
    <svg class="h-6 w-6" aria-hidden="true">
      <use href="/icons/icons.svg#download"></use>
    </svg>
  </Button>
</div>

<style>
  @keyframes btnReveal {
    0% {
      opacity: 0.1;
      transform: translateY(10px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  a {
    opacity: 1;
    transform: translateY(0);
    animation: btnReveal 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    transition:
      background-color 0.2s,
      border-color 0.2s;
  }
</style>
