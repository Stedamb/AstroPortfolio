---
const { text, delay = 0, className = '' } = Astro.props;
const chars = Array.from(text);
---

<div class="overflow-hidden">
  <div class={className} data-animated-text data-base-delay={delay}>
    {
      chars.map((char) => (
        <span>
          {char === ' ' ? '\u00A0' : char}
        </span>
      ))
    }
  </div>
</div>

<style>
  span {
    display: inline-block;
    transform: translateY(100%);
    opacity: 0;
    transition: transform 1s cubic-bezier(0.77, 0, 0.175, 1), opacity 1s cubic-bezier(0.77, 0, 0.175, 1);
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const containers = document.querySelectorAll('[data-animated-text]');
    containers.forEach((container) => {
      const el = container as HTMLElement;
      const baseDelay = parseFloat(el.dataset.baseDelay || '0');
      const chars = container.querySelectorAll('span');
      chars.forEach((char, i) => {
        const ms = (baseDelay + i * 0.08) * 1000;
        setTimeout(() => {
          const el = char as HTMLElement;
          el.style.transform = 'translateY(0)';
          el.style.opacity = '1';
        }, ms);
      });
    });
  });
</script>
