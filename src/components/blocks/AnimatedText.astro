---
const { text, delay = 0, className = '' } = Astro.props;
const chars = Array.from(text);
---

<div class="overflow-hidden">
  <div class={className} data-animated-text data-base-delay={delay}>
    {
      chars.map((char, i) => (
        <span style={`--delay: ${delay + i * 0.08}s`}>
          {char === ' ' ? '\u00A0' : char}
        </span>
      ))
    }
  </div>
</div>

<style>
  @keyframes clipReveal {
    from {
      clip-path: polygon(0 0, 0 0, 0 100%, 0 100%);
    }
    to {
      clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%);
    }
  }

  span {
    display: inline-block;
    clip-path: polygon(0 0, 0 0, 0 100%, 0 100%);
    will-change: clip-path;
  }

  [data-animated] span {
    animation: clipReveal 1s cubic-bezier(0.77, 0, 0.175, 1) var(--delay) both;
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll<HTMLElement>('[data-animated-text]').forEach((el) => {
      el.dataset.animated = '';
    });
  });
</script>
