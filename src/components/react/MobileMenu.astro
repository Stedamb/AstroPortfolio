---
import { routes } from '@/data/routes';

const isHome = Astro.url.pathname === '/';
const navRoutes = isHome ? routes.filter((r) => r.href !== '/') : routes;
---

<div class="lg:hidden" id="mobile-menu">
  <button
    id="menu-toggle"
    class="text-foreground hover:text-muted-foreground active:scale-95 relative z-50 p-4 opacity-75 transition-transform focus:outline-hidden"
    aria-label="Toggle Menu"
  >
    <div id="menu-icon" class="transition-transform duration-300">
      <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
    </div>
  </button>

  <div
    id="menu-overlay"
    class="fixed inset-0 min-h-screen bg-black transition-opacity duration-300 pointer-events-none opacity-0"
  >
    <div class="flex min-h-screen flex-col items-center justify-center">
      <nav class="flex flex-col items-center gap-12 py-8">
        {
          navRoutes.map((item, i) => (
            <a
              href={isHome || item.href.startsWith('/') ? item.href : '/' + item.href}
              class="menu-link text-foreground hover:text-primary group relative font-serif text-2xl italic transition-all duration-300 hover:scale-110 active:scale-95"
              style={`animation-delay: ${0.2 + i * 0.1}s`}
            >
              {item.name}
              <span class="from-primary to-primary/50 absolute -bottom-2 left-0 h-0.5 w-0 bg-linear-to-r transition-all duration-300 group-hover:w-full" />
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</div>

<style>
  @keyframes mobileFadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .menu-link {
    opacity: 0;
    animation: mobileFadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const overlay = document.getElementById('menu-overlay');
  const icon = document.getElementById('menu-icon');
  const links = document.querySelectorAll<HTMLAnchorElement>('.menu-link');
  let isOpen = false;

  function setOpen(open: boolean) {
    isOpen = open;
    document.body.style.overflow = open ? 'hidden' : 'unset';

    if (open) {
      overlay?.classList.remove('pointer-events-none', 'opacity-0');
      overlay?.classList.add('pointer-events-auto', 'opacity-100');
      icon!.style.rotate = '90deg';
      links.forEach((link) => {
        link.style.animationPlayState = 'running';
      });
    } else {
      overlay?.classList.add('pointer-events-none', 'opacity-0');
      overlay?.classList.remove('pointer-events-auto', 'opacity-100');
      icon!.style.rotate = '0deg';
      links.forEach((link) => {
        link.style.animation = 'none';
        link.offsetHeight; // trigger reflow
        link.style.animation = '';
      });
    }
  }

  toggle?.addEventListener('click', () => setOpen(!isOpen));

  links.forEach((link) => {
    link.addEventListener('click', () => setOpen(false));
  });
</script>
