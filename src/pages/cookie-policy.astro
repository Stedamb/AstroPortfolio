---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Cookie Policy - Stefano D'Ambrosio">
  <section class="bg-linear-to-br from-blue-500/[0.03] to-cyan-500/[0.03]">
    <div class="mx-auto max-w-3xl px-6 py-32">
    <h1 class="mb-8 text-center font-serif text-5xl font-bold">Cookie Policy</h1>
    <p class="mb-12 text-center text-foreground/70">Last updated: June 2026</p>

    <div class="space-y-6 text-foreground/80 leading-relaxed">
      <section>
        <h2 class="mb-3 text-2xl font-semibold text-foreground">What Are Cookies</h2>
        <p>
          Cookies are small text files stored on your device when you visit a website. They help the
          site remember your preferences and improve your browsing experience.
        </p>
      </section>

      <section>
        <h2 class="mb-3 text-2xl font-semibold text-foreground">How We Use Cookies</h2>
        <p>
          This site uses <strong>Google Tag Manager (GTM)</strong> to manage analytics and tracking
          tags. GTM itself is a cookie-less tag management system, but the tags it deploys may set
          cookies for analytics purposes (e.g., page views, session duration).
        </p>
        <p class="mt-2">
          We only load GTM <strong>after you explicitly accept</strong> cookies via the consent
          banner. If you reject, no tracking scripts are loaded.
        </p>
      </section>

      <section>
        <h2 class="mb-3 text-2xl font-semibold text-foreground">Types of Cookies Used</h2>
        <ul class="list-disc space-y-2 pl-6">
          <li>
            <strong>Analytics cookies</strong> — collected via Google Tag Manager to understand how
            visitors interact with the site (pages visited, time spent, etc.). These are anonymous
            and used solely for improvement.
          </li>
          <li>
            <strong>Functional cookies</strong> — your consent preference is stored in a
            cookie so the banner does not reappear on every visit.
          </li>
        </ul>
      </section>

      <section>
        <h2 class="mb-3 text-2xl font-semibold text-foreground">Managing Your Consent</h2>
        <p>
          You can withdraw or change your consent at any time by clearing your browser's cookies
          for this site. The cookie banner will then reappear on your next visit.
        </p>
      </section>

      <section>
        <h2 class="mb-3 text-2xl font-semibold text-foreground">Third-Party Services</h2>
        <p>
          Google Tag Manager may deploy cookies from Google Analytics. Google's use of this data is
          governed by their
          <a
            href="https://policies.google.com/privacy"
            class="text-foreground underline-offset-4 hover:underline"
          >
            Privacy Policy
          </a>.
        </p>
      </section>

      <section>
        <h2 class="mb-3 text-2xl font-semibold text-foreground">Contact</h2>
        <p>
          For questions about this cookie policy, reach out at
          <a
            href="mailto:stedamb@protonmail.com"
            class="text-foreground underline-offset-4 hover:underline"
          >
            stedamb@protonmail.com
          </a>.
        </p>
      </section>
    </div>
    </div>
  </section>
</Layout>
