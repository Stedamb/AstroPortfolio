---
import Layout from '@/layouts/Layout.astro';
import { site } from '@/data/site';
---

<Layout title="Cookie Policy - Stefano D'Ambrosio">
  <section class="bg-linear-to-br from-blue-500/[0.03] to-cyan-500/[0.03]">
    <div class="mx-auto max-w-3xl px-6 py-32">
      <h1 class="mb-8 text-center font-serif text-5xl font-bold">Cookie Policy</h1>
      <p class="mb-12 text-center text-foreground/70">Last updated: June 2026</p>

      <div class="space-y-6 text-foreground/80 leading-relaxed">
        <section>
          <h2 class="mb-3 text-2xl font-semibold text-foreground">What Are Cookies</h2>
          <p>
            Cookies are small text files stored on your device when you visit a website. They help
            the site remember your preferences and improve your browsing experience.
          </p>
        </section>

        <section>
          <h2 class="mb-3 text-2xl font-semibold text-foreground">How We Use Cookies</h2>
          <p>
            This site uses <strong>Google Tag Manager (GTM)</strong> to manage analytics tags.
            GTM is a cookie-less tag management system and does not set cookies by itself. However,
            the tags it deploys — specifically <strong>Google Analytics 4</strong> — may set cookies
            for analytics purposes.
          </p>
          <p class="mt-2">
            GTM and GA4 <strong>only load after you explicitly accept</strong> cookies via the
            consent banner. If you reject, no tracking scripts or analytics cookies are placed on
            your device.
          </p>
        </section>

        <section>
          <h2 class="mb-3 text-2xl font-semibold text-foreground">Cookies Used on This Site</h2>
          <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
              <thead>
                <tr class="border-b border-white/12.5">
                  <th class="py-2 pr-4 font-semibold text-foreground">Cookie</th>
                  <th class="py-2 pr-4 font-semibold text-foreground">Type</th>
                  <th class="py-2 pr-4 font-semibold text-foreground">Purpose</th>
                  <th class="py-2 font-semibold text-foreground">Duration</th>
                </tr>
              </thead>
              <tbody class="text-foreground/70">
                <tr class="border-b border-white/12.5">
                  <td class="py-2 pr-4"><code>cookie-consent</code></td>
                  <td class="py-2 pr-4">Functional</td>
                  <td class="py-2 pr-4">Stores your consent preference so the banner does not reappear</td>
                  <td class="py-2">12 months</td>
                </tr>
                <tr>
                  <td class="py-2 pr-4"><code>_ga</code>, <code>_ga_*</code></td>
                  <td class="py-2 pr-4">Analytics</td>
                  <td class="py-2 pr-4">Google Analytics 4 — anonymous usage statistics</td>
                  <td class="py-2">Up to 26 months</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <section>
          <h2 class="mb-3 text-2xl font-semibold text-foreground">Managing Your Consent</h2>
          <p>
            You can withdraw or change your consent at any time by clearing your browser's cookies
            for this site. The cookie banner will reappear on your next visit, allowing you to make
            a new choice.
          </p>
        </section>

        <section>
          <h2 class="mb-3 text-2xl font-semibold text-foreground">Third-Party Services</h2>
          <p>
            Google Analytics 4 cookies are managed through Google Tag Manager. Google's use of this
            data is governed by their
            <a
              href="https://policies.google.com/privacy"
              class="text-foreground underline-offset-4 hover:underline"
            >
              Privacy Policy
            </a>.
            You can learn more about Google Analytics cookies at
            <a
              href="https://developers.google.com/analytics/devguides/collection/ga4/cookies"
              class="text-foreground underline-offset-4 hover:underline"
            >
              Google's Cookie Documentation
            </a>.
          </p>
        </section>

        <section>
          <h2 class="mb-3 text-2xl font-semibold text-foreground">Contact</h2>
          <p>
            For questions about this cookie policy, reach out at
            <a
              href={`mailto:${site.email}`}
            >
              {site.email}
            </a>.
          </p>
        </section>
      </div>
    </div>
  </section>
</Layout>
